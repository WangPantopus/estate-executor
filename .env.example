# ===========================================
# Estate Executor OS — Environment Variables
# ===========================================
# Copy this file to .env and fill in values

# ---- Database ----
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/estate_executor
DATABASE_URL_SYNC=postgresql://postgres:postgres@localhost:5432/estate_executor
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=estate_executor

# ---- Redis ----
REDIS_URL=redis://localhost:6379/0

# ---- Auth0 ----
AUTH0_DOMAIN=your-tenant.us.auth0.com
AUTH0_API_AUDIENCE=https://api.estate-executor.com
AUTH0_CLIENT_ID=your-client-id
AUTH0_CLIENT_SECRET=your-client-secret

# ---- Anthropic (Claude API) ----
ANTHROPIC_API_KEY=sk-ant-xxx

# ---- AWS S3 (Document Storage) ----
AWS_S3_BUCKET=estate-executor-documents
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key

# ---- Stripe ----
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# ---- Email (Resend) ----
RESEND_API_KEY=re_xxx
EMAIL_FROM=notifications@estate-executor.com

# ---- Application ----
APP_ENV=development
APP_SECRET_KEY=change-me-to-a-random-secret
BACKEND_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000
BACKEND_CORS_ORIGINS=http://localhost:3000

# ---- Encryption (Field-Level) ----
ENCRYPTION_MASTER_KEY=change-me-to-a-32-byte-hex-key

# ---- Celery ----
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
